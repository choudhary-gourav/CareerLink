src/main/resources/application-local.properties

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── Node (frontend lives in a different folder) ──────────────
node_modules
npm-debug.log

# ── Docs ─────────────────────────────────────────────────────
README.md
HELP.md

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
